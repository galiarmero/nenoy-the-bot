{
  "name": "nenoy-the-bot",
  "version": "1.0.0",
  "description": "Personal assistant Telegram bot",
  "main": "src/bot.js",
  "scripts": {
    "start": "node src/bot.js",
    "fetch-puzzles": "node scripts/fetch-puzzles.js",
    "build": "npm run fetch-puzzles",
    "dev": "npm run dev:webhook",
    "predev:webhook": "npm run fetch-puzzles",
    "dev:webhook": "DEBUG='telegraf:*' nodemon server.js",
    "predev:polling": "npm run fetch-puzzles",
    "dev:polling": "DEBUG='telegraf:*' UPDATE_METHOD='polling' nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "telegram",
    "bot"
  ],
  "author": "Gali Armero",
  "license": "MIT",
  "dependencies": {
    "axios": "^0.27.2",
    "axios-retry": "^3.4.0",
    "dotenv": "^16.0.1",
    "fastify": "^4.5.3",
    "fastify-plugin": "^4.2.1",
    "telegraf": "^4.9.1"
  },
  "devDependencies": {
    "ngrok": "^4.3.3",
    "nodemon": "^2.0.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/galiarmero/nenoy-the-bot.git"
  },
  "bugs": {
    "url": "https://github.com/galiarmero/nenoy-the-bot/issues"
  },
  "homepage": "https://github.com/galiarmero/nenoy-the-bot#readme",
  "engines": {
    "node": "22.x"
  }
}
